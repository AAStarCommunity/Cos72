# =============================================================================
# Sepolia Testnet — Complete Configuration Reference
# cp env.sepolia.example .env.sepolia, fill in placeholders, never commit .env.sepolia
# After deploy: write GTOKEN_SALE_ADDRESS + APNTS_SALE_ADDRESS here
# =============================================================================

# --- Runtime ---
PORT=3000
NODE_ENV=production
CHAIN_ID=11155111
DB_TYPE=json

# --- RPC ---
ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<YOUR_ALCHEMY_KEY>
BUNDLER_RPC_URL=https://api.pimlico.io/v2/11155111/rpc?apikey=<YOUR_PIMLICO_KEY>

# --- JWT / Encryption ---
JWT_SECRET=<YOUR_JWT_SECRET>
JWT_EXPIRES_IN=7d
USER_ENCRYPTION_KEY=<YOUR_ENCRYPTION_KEY>
DATA_TOOLS_PASSWORD=<YOUR_ADMIN_PASSWORD>

# --- KMS / BLS ---
BLS_SEED_NODES=https://v1.aastar.io
KMS_ENABLED=true
KMS_ENDPOINT=https://kms1.aastar.io
KMS_API_KEY=<YOUR_KMS_API_KEY>

# --- EntryPoint / AA (Sepolia) ---
ENTRY_POINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
ENTRY_POINT_V7_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
AASTAR_ACCOUNT_FACTORY_V7_ADDRESS=0x91E60482a2B343004dF29EB205C4F6916E864700
VALIDATOR_CONTRACT_V7_ADDRESS=0xD9756c11686B59F7DDf39E6360230316710485af
DEFAULT_ENTRYPOINT_VERSION=0.7

# --- AAStar Core Contracts (Sepolia canonical, all verified on-chain) ---
REGISTRY_ADDRESS=0x7Ba70C5bFDb3A4d0cBd220534f3BE177fefc1788
STAKING_ADDRESS=0x1118eAf2427a5B9e488e28D35338d22EaCBc37fC
SUPER_PAYMASTER_ADDRESS=0x16cE0c7d846f9446bbBeb9C5a84A4D140fAeD94A
GTOKEN_ADDRESS=0x9ceDeC089921652D050819ca5BE53765fc05aa9E
XPNTS_FACTORY_ADDRESS=0x6EafdA3477F3eec1F848505e1c06dFB5532395b6
PAYMASTER_FACTORY_ADDRESS=0xfDE4671581F21C9e54Cafa95FA6Da98678750F4d
MYSBT_ADDRESS=0x677423f5Dad98D19cAE8661c36F094289cb6171a
APNTS_ADDRESS=0xDf669834F04988BcEE0E3B6013B6b867Bd38778d
PRICE_FEED_ADDRESS=0x694AA1769357215DE4FAC081bf1f309aDC325306

# =============================================================================
# DEPLOYMENT SECTION — fill in before/after running forge scripts
# =============================================================================

# Deploy inputs (required before running deploy scripts)
PRIVATE_KEY_SUPPLIER=<DEPLOYER_WALLET_PRIVATE_KEY>       # must have Sepolia ETH
TREASURY_ADDRESS=<TREASURY_WALLET_ADDRESS>                # receives USDC from sales
USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238  # Sepolia USDC (Circle official)

# Deploy outputs — DEPLOYED 2026-03-15, verified on Sepolia Etherscan
GTOKEN_SALE_ADDRESS=0xfb1D40C882aDe3402B41ACc3260FC59a3E18aA9b
APNTS_SALE_ADDRESS=0x7fcDab5970697B130eA87d0c500dC213f4ba499F

# --- Deploy commands (run from the contracts directory) ---
#
# 1. GTokenSaleContract:
#    forge script script/DeploySaleContract.s.sol \
#      --rpc-url $ETH_RPC_URL --private-key $PRIVATE_KEY_SUPPLIER \
#      --broadcast --verify
#
# 2. APNTsSaleContract:
#    APNTS_ADDRESS=0xDf669834F04988BcEE0E3B6013B6b867Bd38778d \
#    TREASURY_ADDRESS=<TREASURY_WALLET_ADDRESS> \
#    USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238 \
#    forge script script/DeployAPNTsSaleContract.s.sol \
#      --rpc-url $ETH_RPC_URL --private-key $PRIVATE_KEY_SUPPLIER \
#      --broadcast --verify
