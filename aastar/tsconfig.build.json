{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmitOnError": false,
    "paths": {
      "ox": ["./node_modules/ox/_types/index.d.ts"],
      "ox/*": ["./node_modules/ox/_types/*.d.ts"]
