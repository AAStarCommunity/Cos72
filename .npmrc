# @aastar/sdk declares peerOptional react ^18, but this app runs React 19.
# legacy-peer-deps lets install/ci accept that (harmless: peer is optional).
# react/react-dom are also pinned in root overrides + root devDependencies so
# React 19 hoists to the root node_modules (root `next build` needs it there).
legacy-peer-deps=true
